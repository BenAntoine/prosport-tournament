    image_url: "https://images.unsplash.com/photo-1517466787929-bc90951d0974?auto=format&fit=crop&w=600&q=80",
    description: "Jeune équipe universitaire dynamique avec une excellente cohésion.",
    status: "active",
    sport: "Football",
    home_city: "Marseille",
    players_count: 22
  },
  {
    id: 4,
