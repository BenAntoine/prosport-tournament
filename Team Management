"use client";

import { FormEvent, useEffect, useMemo, useState } from "react";

// Configuration de la base de données distante Supabase
const supabaseUrl = "https://djvqynczrefmsvjjhzrx.supabase.co";
const supabaseAnonKey = "sb_publishable_FI1uEmZb14jps8kO30RyEg_iZaqdKMk";

// --- DÉFINITION DES TYPES ET INTERFACES ---
export type TeamStatus = 'active' | 'eliminated' | 'pending' | 'inactive';
export type TeamCategory = 'pro' | 'amateur' | 'youth' | 'varsity';

export interface Venue {
  id: number;
  name: string;
  city: string;
}

export interface TeamRecord {
  id: number;
  venue_id: number | null; // ID du stade associé
  name: string;            // Nom du club (ex: Metropolis Strikers)
  coach: string;           // Entraîneur principal
  founded_year: number;    // Année de création du club
  category: TeamCategory;  // Niveau de compétition
  registration_fee: number;// Cotisation d'inscription
  status: TeamStatus;      // Position dans la ligue
  image_url: string;       // Logo d'illustration
  description: string;     // Présentation courte
  sport: string;           // Discipline
  home_city: string;       // Ville
  players_count: number;   // Nombre de licenciés
}

// Données de secours des stades
