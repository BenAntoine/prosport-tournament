                      </td>
                      <td className="py-4">
                        <span className="rounded bg-blue-900/30 px-2.5 py-1 text-xs font-semibold text-blue-300">
                          {reg.sport}
                        </span>
                      </td>
                      <td className="py-4">{reg.captain_name}</td>
                      <td className="py-4">{reg.players_count} athlètes</td>
                      <td className="py-4 text-xs font-mono">{reg.registration_date}</td>
                      <td className="py-4 font-bold text-blue-400">{reg.total_cost} €</td>
                      <td className="py-4">
                        <span className={`inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium uppercase ${
                          reg.status === 'confirmed'
                            ? "bg-emerald-950 text-emerald-400"
                            : reg.status === 'pending'
                            ? "bg-amber-950 text-amber-400"
                            : "bg-red-950 text-red-400"
                        }`}>
                          <span className={`h-1.5 w-1.5 rounded-full ${
                            reg.status === 'confirmed' ? "bg-emerald-400" : reg.status === 'pending' ? "bg-amber-400" : "bg-red-400"
                          }`} />
                          {reg.status === 'confirmed' ? 'Validé' : reg.status === 'pending' ? 'En attente' : 'Refusé'}
                        </span>
                      </td>
                    </tr>
                  ))}

                  {registrations.length === 0 && (
                    <tr>
                      <td colSpan={8} className="py-8 text-center text-[#8a94a6] text-sm">
                        Aucune demande d'inscription trouvée sur votre SGBD.
                      </td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {/* ÉTAPE C : CLASSEMENTS ET PROCHAINES RECONTRES */}
        {activeSection === "stats" && (
          <div className="grid gap-6 md:grid-cols-3">
            <div className="col-span-2 rounded-2xl border border-[#222733] bg-[#11141a] p-6">
              <h2 className="text-xl font-black text-white mb-4">Classement Général de la Ligue</h2>
              <p className="text-xs text-[#8a94a6] mb-6">Mise à jour en direct via le module PostgreSQL.</p>
              
              <div className="space-y-4">
                {[
                  { rank: 1, name: "Metropolis Strikers", pts: 28, win: 9, draw: 1, lost: 0, form: "🟢🟢🟢🟢🟢" },
                  { rank: 2, name: "Apex Titans", pts: 24, win: 8, draw: 0, lost: 2, form: "🟢🟢🔴🟢🟢" },
                  { rank: 3, name: "Vanguard Eagles", pts: 18, win: 5, draw: 3, lost: 2, form: "🟡🟢🟡🔴🟡" },
                  { rank: 4, name: "Coastal Mavericks", pts: 12, win: 3, draw: 3, lost: 4, form: "🔴🟡🟢🔴🟢" }
                ].map((row) => (
                  <div key={row.rank} className="flex items-center justify-between rounded-xl bg-black/40 p-4 border border-[#222733]">
                    <div className="flex items-center gap-4">
                      <span className={`flex h-7 w-7 items-center justify-center rounded-full text-xs font-black ${
                        row.rank === 1 ? "bg-amber-400 text-black" : row.rank === 2 ? "bg-slate-300 text-black" : "bg-orange-600 text-white"
                      }`}>
                        {row.rank}
                      </span>
                      <div>
                        <h4 className="font-bold text-white text-sm">{row.name}</h4>
                        <p className="text-xs text-[#8a94a6]">{row.win} V - {row.draw} N - {row.lost} D</p>
                      </div>
                    </div>
                    <div className="text-right">
                      <p className="text-base font-black text-blue-400">{row.pts} PTS</p>
                      <p className="text-[10px] tracking-wider font-mono">{row.form}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div className="rounded-2xl border border-[#222733] bg-[#11141a] p-6">
              <h2 className="text-xl font-black text-white mb-4">Prochains Matchs</h2>
              <div className="flow-root mt-6">
                <ul className="-my-5 divide-y divide-[#222733] text-sm">
                  {[
                    { id: 1, date: "20 Mai 2026", match: "Strikers FC vs Eagles", venue: "Stade Métropolitain" },
                    { id: 2, date: "24 Mai 2026", match: "Mavericks vs Strikers", venue: "Gymnase de la Côte" },
                    { id: 3, date: "30 Mai 2026", match: "Apex Titans vs Warriors", venue: "Aréna des Titans" }
                  ].map((fixture) => (
                    <li key={fixture.id} className="py-4">
                      <div className="flex items-center space-x-4">
                        <div className="flex-1 min-w-0">
                          <p className="text-sm font-bold text-white truncate">{fixture.match}</p>
                          <p className="text-xs text-[#8a94a6] truncate">🏟️ {fixture.venue}</p>
                        </div>
                        <div className="inline-flex items-center text-xs font-mono font-bold text-blue-400 bg-blue-950/40 rounded px-2 py-1">
                          {fixture.date}
                        </div>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        )}

      </main>

      {/* FORMULAIRE D'ENGAGEMENT COMPÉTITION (MODAL COMPOSANT) */}
      {modalOpen && selectedTeam && (
        <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm animate-fade-in">
          <div className="w-full max-w-md rounded-2xl border border-[#222733] bg-[#11141a] p-6 shadow-2xl">
            <div className="flex items-start justify-between border-b border-[#222733] pb-4">
              <div>
                <h3 className="text-lg font-black text-white">S'inscrire à la compétition</h3>
                <p className="text-xs text-[#8a94a6]">Soumission officielle de la feuille d'effectif</p>
              </div>
              <button
                onClick={() => setModalOpen(false)}
                className="text-gray-400 hover:text-white text-lg font-bold"
              >
                ✕
              </button>
            </div>

            <form onSubmit={handleRegisterSubmit} className="mt-4 flex flex-col gap-4">
              
              <div className="rounded-xl bg-black/40 p-3 border border-[#222733]">
                <p className="text-xs font-bold text-blue-400 uppercase tracking-wide">{selectedTeam.sport}</p>
                <p className="text-sm font-bold text-white">{selectedTeam.name}</p>
                <p className="text-xs text-[#8a94a6] mt-1">Stade : {selectedTeam.home_city} | Frais d'adhésion : {selectedTeam.registration_fee} €</p>
              </div>

              {/* Champ Capitaine */}
              <div>
                <label className="block text-xs font-bold uppercase tracking-wider text-[#8a94a6] mb-1">
                  Nom du Capitaine d'Équipe
                </label>
                <input
                  type="text"
                  required
                  className="w-full rounded-lg border border-[#222733] bg-black/40 px-3 py-2 text-sm text-white focus:border-[#2563eb] focus:outline-none"
                  value={captainName}
                  onChange={(e) => setCaptainName(e.target.value)}
                />
              </div>

              {/* Champ Effectif athlètes */}
              <div>
                <label className="block text-xs font-bold uppercase tracking-wider text-[#8a94a6] mb-1">
                  Nombre de Licenciés à engager
                </label>
                <input
                  type="number"
                  min={5}
                  max={30}
                  className="w-full rounded-lg border border-[#222733] bg-black/40 px-3 py-2 text-sm text-white focus:border-[#2563eb] focus:outline-none"
                  value={customPlayersCount}
                  onChange={(e) => setCustomPlayersCount(Number(e.target.value))}
                />
                <p className="text-[10px] text-[#8a94a6] mt-1">Le SGBD impose un minimum légal de 5 joueurs par club.</p>
              </div>

              {/* Budget récapitulatif */}
              <div className="rounded-lg bg-black/30 p-3 text-xs text-gray-300 border border-[#222733]">
                <div className="flex justify-between font-bold">
                  <span>Montant Total SGBD :</span>
                  <span className="text-blue-400 text-sm">{selectedTeam.registration_fee} €</span>
                </div>
              </div>

              {/* Boutons d'Action */}
              <div className="flex justify-end gap-3 pt-2">
                <button
                  type="button"
                  onClick={() => setModalOpen(false)}
                  className="rounded-full border border-[#222733] px-4 py-2 text-xs font-bold uppercase text-[#8a94a6] hover:border-red-500/40 hover:text-red-400 transition"
                >
                  Annuler
                </button>
                <button
                  type="submit"
                  disabled={savingRegistration}
                  className="rounded-full bg-[linear-gradient(145deg,#2563eb,#1d4ed8)] px-5 py-2 text-xs font-bold uppercase text-white shadow-md disabled:opacity-60"
                >
                  {savingRegistration ? "Enregistrement..." : "Soumettre la feuille"}
                </button>
              </div>
            </form>
          </div>
        </div>
      )}

    </div>
  );
}

// Point d'entrée pour l'environnement isolé de la plateforme
export default function App() {
  return <DashboardPage />;
}
