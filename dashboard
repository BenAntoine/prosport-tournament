          setSupabase(client);
          return;
        } catch (e) {
          console.error("Erreur client :", e);
        }
      }

      const script = document.createElement("script");
      script.src = "https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2";
      script.async = true;
      script.onload = () => {
        if ((window as any).supabase) {
          try {
            const client = (window as any).supabase.createClient(supabaseUrl, supabaseAnonKey);
            setSupabase(client);
          } catch (e) {
            console.error("Erreur post-chargement client :", e);
          }
        }
      };
      document.body.appendChild(script);
    }
  }, []);

  // 2. Récupération des données en temps réel depuis Supabase
  const fetchData = async (client: any) => {
    try {
      // Lecture des Équipes
      const { data: teamsData, error: teamsErr } = await client
        .from("teams")
        .select("*")
        .order("id", { ascending: true });

      if (teamsErr) throw teamsErr;
      if (teamsData && teamsData.length > 0) {
        setTeams(teamsData);
      }

      // Lecture des Inscriptions
      const { data: regsData, error: regsErr } = await client
        .from("registrations")
        .select("*")
        .order("id", { ascending: false });

      if (regsErr) throw regsErr;
      if (regsData) {
        setRegistrations(regsData);
      }
      
      setDataLoaded(true);
    } catch (err: any) {
      console.warn("Mode simulation activé. Supabase inaccessible ou tables non créées.", err.message);
      // Fallback in-memory
      setDataLoaded(true);
    }
  };

  useEffect(() => {
    if (supabase) {
      fetchData(supabase);
    }
  }, [supabase]);

  // Remplir le capitaine lors de la sélection
  useEffect(() => {
    if (user) {
      setCaptainName(user.fullName);
    }
